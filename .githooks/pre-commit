#!/usr/bin/env sh
# Membrana pre-commit gate: gitleaks по staged-изменениям (лист №5 заседания
# security-posture, 19.07.2026 — вердикт M0: секрет-гигиена = машинный гейт).
#
# Мягкий по дистрибуции: если бинарь gitleaks не установлен — предупреждает и
# пропускает (гейт с зубами живёт в CI: .github/workflows/gitleaks.yml).
# Локальная установка (Windows): winget install gitleaks · (mac): brew install gitleaks
#
# Пропустить (аварийно): SKIP_PRECOMMIT=1 git commit ...
if [ "$SKIP_PRECOMMIT" = "1" ]; then
  echo "pre-commit: пропущено (SKIP_PRECOMMIT=1)"
  exit 0
fi

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-commit [№5]: gitleaks не установлен — локальный секрет-скан пропущен (CI проверит)."
  exit 0
fi

echo "pre-commit [№5]: gitleaks protect --staged"
gitleaks protect --staged --no-banner --redact
echo "pre-commit: OK"
