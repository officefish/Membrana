#!/usr/bin/env sh
# Membrana commit-msg gate (NB5, agent-tooling-night-build).
#
# Мягко ведёт к конвенции проекта:
#  - conventional-заголовок `type(scope): subject` (блокирует явно неверный формат);
#  - Co-Authored-By трейлер агента (ТОЛЬКО предупреждение — не блокирует).
# Exempt: merge/revert/fixup/squash/amend-служебные.
# Пропустить: SKIP_COMMIT_MSG=1

[ "$SKIP_COMMIT_MSG" = "1" ] && exit 0

msg_file="$1"
first_line=$(head -1 "$msg_file")

# Служебные сообщения git — не трогаем.
case "$first_line" in
  Merge*|Revert*|"fixup!"*|"squash!"*|"amend!"*) exit 0 ;;
esac

# Conventional-заголовок: type(scope)?: subject
if ! printf '%s' "$first_line" | grep -Eq '^(feat|fix|chore|docs|refactor|test|ci|perf|build|style|revert|comp|cowork)(\([^)]+\))?!?: .+'; then
  echo "commit-msg: заголовок не conventional: «$first_line»" >&2
  echo "  формат: type(scope): subject  (feat|fix|chore|docs|refactor|test|ci|perf|build|style|comp|cowork)" >&2
  echo "  пропустить: SKIP_COMMIT_MSG=1 git commit ..." >&2
  exit 1
fi

# Трейлер агента — предупреждение, не блок.
if ! grep -q 'Co-Authored-By: Claude' "$msg_file"; then
  echo "commit-msg [warn]: нет трейлера 'Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>'" >&2
fi

exit 0
