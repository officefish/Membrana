#!/usr/bin/env sh
# Membrana pre-push gate (cg6 + cg7, спринт tech-debt-2026-07).
#
# Ловит ДО push два локальных футгана, которые роняли CI:
#   cg7: новый плагин без записи в docs/catalog/client/registry.json
#        → catalog:verify-client красный.
#   cg6: stale dist соседнего пакета → одиночный typecheck ловит implicit-any.
#        yarn typecheck идёт через turbo (^build) → dist всегда свежий.
#
# CI уже защищён turbo ^build; хук лишь переносит эти проверки левее (до push),
# чтобы не узнавать о дыре из красного CI.
#
# Пропустить (аварийно): SKIP_PREPUSH=1 git push
if [ "$SKIP_PREPUSH" = "1" ]; then
  echo "pre-push: пропущено (SKIP_PREPUSH=1)"
  exit 0
fi

set -e

# Отказ-I «ответственный не назначен» (cowork-execution-registry, контракт §2/§6-б):
# карточка со status active без leadPersona → жёсткий вердикт 22, push не проходит.
# Гейт читает docs/tasks/registry.json офлайн; сети и yarn ему не нужно.
echo "pre-push [trace-gate]: node scripts/trace-gate.mjs lead-persona"
node scripts/trace-gate.mjs lead-persona

echo "pre-push [cg7]: yarn catalog:verify-client"
yarn catalog:verify-client

echo "pre-push [NB4]: yarn verify:wire-sync (core ↔ background-cabinet)"
yarn verify:wire-sync

# NB5: typecheck сужен до affected-пакетов (изменённые с origin/main + их зависимые),
# turbo ^build держит dist свежим. Быстрее полного прогона → меньше соблазна SKIP.
# Если origin/main недоступен (нет fetch) — fallback на полный typecheck.
echo "pre-push [cg6/NB5]: yarn turbo run typecheck (affected)"
if git rev-parse --verify --quiet origin/main >/dev/null; then
  yarn turbo run typecheck --filter='...[origin/main]'
else
  yarn typecheck
fi

echo "pre-push: OK"
