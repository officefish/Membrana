    "lint:detectors": "turbo run lint --filter=@membrana/detector-base --filter=@membrana/harmonic-detector-service --filter=@membrana/cepstral-detector-service --filter=@membrana/spectral-flux-detector-service --filter=@membrana/template-match-detector-service --filter=@membrana/yamnet-detector-service --filter=@membrana/clap-detector-service --filter=@membrana/agentic-detector-service",
