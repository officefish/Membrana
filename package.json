    "office:build": "yarn workspace @membrana/background-office build",
    "office:verify-swagger": "yarn workspace @membrana/background-office verify:swagger",
    "office:docker:build": "docker compose -f packages/background-office/docker-compose.yml build",
    "office:docker:up": "docker compose -f packages/background-office/docker-compose.yml up -d",
    "office:docker:down": "docker compose -f packages/background-office/docker-compose.yml down",
    "office:docker:logs": "docker compose -f packages/background-office/docker-compose.yml logs -f office-api",
    "office:docker:prod:build": "docker compose -f packages/background-office/docker-compose.yml -f deploy/background-office.prod.compose.yml build",
    "office:docker:prod:up": "docker compose -f packages/background-office/docker-compose.yml -f deploy/background-office.prod.compose.yml --env-file /etc/membrana/office.env up -d",
    "media:dev": "yarn workspace @membrana/background-media dev",
    "media:build": "yarn workspace @membrana/background-media build",
    "media:migrate": "yarn workspace @membrana/background-media prisma:migrate",
    "media:db:up": "docker compose -f packages/background-media/docker-compose.dev.yml up -d",
    "media:db:down": "docker compose -f packages/background-media/docker-compose.dev.yml down",
    "media:docker:build": "docker compose -f packages/background-media/docker-compose.yml build",
