    "consilium": "node scripts/consilium.mjs",
    "team-evening-feedback": "node scripts/team-evening-feedback.mjs",
    "team-evening-feedback:dry": "node scripts/team-evening-feedback.mjs --dry-run",
    "rag:query": "node scripts/rag-query.mjs",
    "rag:index": "yarn workspace @membrana/rag-service build && yarn workspace @membrana/rag-service run index -- --full",
    "rag:index:incremental": "yarn workspace @membrana/rag-service build && yarn workspace @membrana/rag-service run index -- --incremental",
    "archive:daily-review": "node scripts/archive-daily-code-review.mjs",
    "test:scripts": "node --test scripts/context-collector-paths.test.mjs scripts/consilium-paths.test.mjs scripts/main-day-issue-paths.test.mjs scripts/daily-standup-paths.test.mjs scripts/rag-ritual.test.mjs scripts/code-review-ritual.test.mjs scripts/team-evening-feedback-ritual.test.mjs scripts/detection-planning-priorities.test.mjs scripts/task-registry.test.mjs scripts/archive-doc-snapshot.test.mjs scripts/benchmark-metrics.test.mjs scripts/ground-truth-export.test.mjs scripts/verify-mcp-bootstrap.test.mjs scripts/github-issues-audit.test.mjs scripts/usercase-manifest.test.mjs scripts/night-build-router.test.mjs scripts/tasks-audit.test.mjs scripts/context-tooling.test.mjs",
    "task:list": "node scripts/task-list.mjs",
    "task:sync-readme": "node scripts/task-list.mjs --sync-readme",
    "apply:lead-persona": "node scripts/apply-lead-persona-defaults.mjs",
    "apply:strategic-wave": "node scripts/apply-strategic-wave.mjs",
    "task:board": "node scripts/generate-active-tasks-board.mjs",
    "tasks:bookkeeping": "node scripts/tasks-bookkeeping.mjs",
    "tasks:reviewing": "node scripts/tasks-reviewing.mjs",
    "tasks:audit": "node scripts/tasks-audit.mjs",
