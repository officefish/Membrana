{
  "name": "membrana",
  "version": "0.1.0",
  "private": true,
  "description": "Membrana — модульная платформа управления устройствами и расписанием",
  "workspaces": [
    "packages/*",
    "packages/libs/*",
    "packages/services/*",
    "packages/services/detectors/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint --concurrency=3",
    "test": "turbo run test --concurrency=3",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "morning-care": "node scripts/morning-care.mjs",
    "anthropic:smoke": "node scripts/anthropic-smoke.mjs",
    "anthropic:task": "node scripts/anthropic-task.mjs",
    "claude:code": "node scripts/claude-code-with-proxy.mjs",
    "code-review": "node scripts/code-review.mjs",
    "save-code-review": "yarn run archive:daily-review",
    "local-code-review": "node scripts/local-code-review.mjs",
    "local-code-review:full": "node scripts/local-code-review.mjs --full",
    "local-code-review:check": "node scripts/local-code-review.mjs --check",
    "ensure-ollama": "node scripts/ensure-ollama.mjs",
    "archive:daily-day": "node scripts/archive-daily-day-artifacts.mjs",
    "dataset:generate": "node scripts/generate-dataset-synthetics.mjs",
    "dataset:fetch-real": "node scripts/fetch-real-dataset-collection.mjs",
    "dataset:sync-free-v1": "node scripts/sync-free-v1-catalog.mjs",
    "dataset:assign-splits": "node scripts/assign-dataset-splits.mjs",
    "dataset:export-ground-truth": "node scripts/export-ground-truth-manifest.mjs --from-prod",
    "benchmark:detectors": "yarn turbo run build --filter=@membrana/detector-base --filter=@membrana/harmonic-detector-service --filter=@membrana/cepstral-detector-service --filter=@membrana/spectral-flux-detector-service --filter=@membrana/template-match-detector-service && node scripts/benchmark-detectors.mjs",
    "calibrate:detectors": "yarn turbo run build --filter=@membrana/detector-base --filter=@membrana/harmonic-detector-service --filter=@membrana/cepstral-detector-service --filter=@membrana/spectral-flux-detector-service --filter=@membrana/template-match-detector-service && node scripts/calibrate-detectors.mjs",
    "benchmark:fft-trends": "yarn turbo run build --filter=@membrana/fft-analyzer-service --filter=@membrana/trends-detector-service --filter=@membrana/template-match-detector-service && node scripts/benchmark-fft-trends.mjs",
    "templates:build-from-dataset": "yarn workspace @membrana/template-match-detector-service build && node scripts/build-templates-from-dataset.mjs",
    "report:vdr6": "node scripts/generate-vdr6-report.mjs",
    "save-daily-day": "yarn run archive:daily-day",
    "code-review:full": "node scripts/code-review.mjs --full",
    "plan:day": "node scripts/strategic-plan-day.mjs",
    "plan:day:full": "node scripts/strategic-plan-day.mjs --full",
    "plan:week": "node scripts/strategic-plan-week.mjs",
    "plan:week:full": "node scripts/strategic-plan-week.mjs --full",
    "standup": "node scripts/daily-standup.mjs",
    "standup:full": "node scripts/daily-standup.mjs --full",
    "standup:dry": "node scripts/daily-standup.mjs --dry-run",
    "main-day-issue": "node scripts/main-day-issue.mjs",
    "main-day-issue:dry": "node scripts/main-day-issue.mjs --dry-run",
    "main-day-issue:full": "node scripts/main-day-issue.mjs --full",
    "ritual:day": "node scripts/morning-care.mjs && node scripts/strategic-plan-day.mjs && node scripts/daily-standup.mjs && node scripts/main-day-issue.mjs",
    "ritual:evening": "node scripts/archive-daily-day-artifacts.mjs && node scripts/code-review.mjs && node scripts/archive-daily-code-review.mjs",
    "ritual:evening:local": "yarn archive:daily-day && yarn ensure-ollama && yarn local-code-review && yarn save-code-review && yarn task:close-github",
    "night:open": "node scripts/night-build-open.mjs",
    "night:close": "node scripts/night-build-close.mjs",
    "night:checkpoint": "node scripts/night-build-checkpoint.mjs",
    "ritual:day:no-api": "node scripts/morning-care.mjs --no-anthropic && node scripts/daily-standup.mjs --dry-run && node scripts/main-day-issue.mjs --allow-missing-standup",
    "analyzers:research:week": "node scripts/analyzers-research-week.mjs",
    "analyzers:research:week:dry": "node scripts/analyzers-research-week.mjs --dry-run",
    "ask": "node scripts/ask-persona.mjs",
    "consilium": "node scripts/consilium.mjs",
    "archive:daily-review": "node scripts/archive-daily-code-review.mjs",
    "test:scripts": "node --test scripts/context-collector-paths.test.mjs scripts/consilium-paths.test.mjs scripts/main-day-issue-paths.test.mjs scripts/daily-standup-paths.test.mjs scripts/detection-planning-priorities.test.mjs scripts/task-registry.test.mjs scripts/archive-doc-snapshot.test.mjs scripts/benchmark-metrics.test.mjs scripts/ground-truth-export.test.mjs scripts/verify-mcp-bootstrap.test.mjs",
    "task:list": "node scripts/task-list.mjs",
    "task:sync-readme": "node scripts/task-list.mjs --sync-readme",
    "catalog:verify-client": "node scripts/verify-client-catalog.mjs",
    "task:archive": "node scripts/archive-task.mjs",
    "hackathon:close": "node scripts/hackathon-close.mjs",
    "task:close-github": "node scripts/task-close-github-issues.mjs",
    "task:close-github:dry": "node scripts/task-close-github-issues.mjs --dry-run",
    "test:detectors": "turbo run test --filter=@membrana/detector-base --filter=@membrana/harmonic-detector-service --filter=@membrana/cepstral-detector-service --filter=@membrana/spectral-flux-detector-service --filter=@membrana/template-match-detector-service --filter=@membrana/yamnet-detector-service --filter=@membrana/clap-detector-service --filter=@membrana/agentic-detector-service",
    "lint:detectors": "turbo run lint --filter=@membrana/detector-base --filter=@membrana/harmonic-detector-service --filter=@membrana/cepstral-detector-service --filter=@membrana/spectral-flux-detector-service --filter=@membrana/template-match-detector-service --filter=@membrana/yamnet-detector-service --filter=@membrana/clap-detector-service --filter=@membrana/agentic-detector-service",
    "office:dev": "yarn workspace @membrana/background-office dev",
    "office:build": "yarn workspace @membrana/background-office build",
    "office:verify-swagger": "yarn workspace @membrana/background-office verify:swagger",
    "media:dev": "yarn workspace @membrana/background-media dev",
    "media:build": "yarn workspace @membrana/background-media build",
    "media:migrate": "yarn workspace @membrana/background-media prisma:migrate",
    "media:db:up": "docker compose -f packages/background-media/docker-compose.dev.yml up -d",
    "media:db:down": "docker compose -f packages/background-media/docker-compose.dev.yml down",
    "media:docker:build": "docker compose -f packages/background-media/docker-compose.yml build",
    "media:docker:up": "docker compose -f packages/background-media/docker-compose.yml up -d",
    "media:docker:down": "docker compose -f packages/background-media/docker-compose.yml down",
    "media:docker:logs": "docker compose -f packages/background-media/docker-compose.yml logs -f media-api",
    "media:docker:prod:build": "docker compose -f packages/background-media/docker-compose.yml -f deploy/background-media.prod.compose.yml build",
    "media:docker:prod:up": "docker compose -f packages/background-media/docker-compose.yml -f deploy/background-media.prod.compose.yml --env-file /etc/membrana/media.env up -d",
    "media:verify-swagger": "yarn workspace @membrana/background-media verify:swagger",
    "media:cors:cabinet-prod": "node scripts/_ssh-media-cabinet-cors-fix.mjs",
    "media:provision-catalog": "node scripts/media-provision-catalog.mjs",
    "cabinet:dev": "yarn workspace @membrana/background-cabinet dev",
    "cabinet:build": "yarn workspace @membrana/background-cabinet build",
    "cabinet:migrate": "yarn workspace @membrana/background-cabinet prisma:migrate",
    "cabinet:migrate:dev": "yarn workspace @membrana/background-cabinet prisma:migrate:dev",
    "cabinet:seed": "yarn workspace @membrana/background-cabinet prisma:seed",
    "cabinet:db:up": "docker compose -f packages/background-cabinet/docker-compose.dev.yml up -d",
    "cabinet:db:down": "docker compose -f packages/background-cabinet/docker-compose.dev.yml down",
    "cabinet:app:dev": "yarn workspace @membrana/cabinet dev",
    "cabinet:docker:build": "docker compose -f packages/background-cabinet/docker-compose.yml build",
    "cabinet:docker:up": "docker compose -f packages/background-cabinet/docker-compose.yml up -d",
    "cabinet:docker:down": "docker compose -f packages/background-cabinet/docker-compose.yml down",
    "cabinet:docker:smoke": "docker compose -f packages/background-cabinet/docker-compose.yml ps && curl -fsS http://localhost:3020/health",
    "mcp:verify-bootstrap": "node scripts/verify-mcp-bootstrap.mjs",
    "mcp:phase-a": "node scripts/mcp-workstation-phase-a.mjs",
    "mcp:phase-a:install": "node scripts/mcp-workstation-phase-a.mjs --write",
    "mcp:phase-b": "node scripts/mcp-workstation-phase-b.mjs",
    "mcp:phase-b:install": "node scripts/mcp-workstation-phase-b.mjs --write",
    "mcp:phase-c": "node scripts/mcp-workstation-phase-c.mjs",
    "mcp:phase-c:install": "node scripts/mcp-workstation-phase-c.mjs --write",
    "cabinet:deploy:prod": "node scripts/_ssh-cabinet-deploy.mjs",
    "cabinet:deploy:image:prod": "node scripts/_ssh-cabinet-deploy-image.mjs",
    "cabinet:rollback:prod": "node scripts/_ssh-cabinet-rollback.mjs",
    "cabinet:smoke:prod": "node scripts/_ssh-cabinet-smoke.mjs",
    "device-board:deploy:prod": "node scripts/_ssh-device-board-deploy.mjs",
    "cabinet:mp3:post-deploy": "node scripts/_ssh-cabinet-mp3-post-deploy.mjs",
    "cabinet:mp3:smoke": "node scripts/_ssh-cabinet-mp3-smoke.mjs",
    "cabinet:mp3:prod": "node scripts/_ssh-cabinet-mp3-prod.mjs",
    "cabinet:quota-refactor:prod": "node scripts/_ssh-cabinet-quota-refactor-prod.mjs",
    "cabinet:mp4:prod": "node scripts/_ssh-cabinet-mp4-prod.mjs",
    "cabinet:pair-unlink:prod": "node scripts/_ssh-cabinet-pair-unlink-prod.mjs",
    "cabinet:mp5:prod": "node scripts/_ssh-cabinet-mp5-prod.mjs",
    "cabinet:mp6:prod": "node scripts/_ssh-cabinet-mp6-prod.mjs",
    "cabinet:mp7:prod": "node scripts/_ssh-cabinet-mp7-prod.mjs",
    "studio:dev": "node scripts/studio-dev.mjs",
    "studio:build": "node scripts/studio-build.mjs",
    "studio:package": "node scripts/studio-package.mjs",
    "cabinet:tj6:prod": "node scripts/_ssh-cabinet-tj6-live-journal-smoke.mjs",
    "cabinet:pairing:e2e:deploy": "node scripts/_ssh-cabinet-pairing-e2e-deploy.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "ssh2": "^1.16.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "undici": "^6.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "resolutions": {
    "estree-walker": "2.0.2",
    "express": "4.21.2"
  },
  "packageManager": "yarn@4.5.0"
}
