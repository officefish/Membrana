    "cabinet:pairing:e2e:deploy": "node scripts/_ssh-cabinet-pairing-e2e-deploy.mjs",
    "recording-parity:smoke-matrix": "node scripts/recording-parity-smoke-matrix.mjs",
    "trends-parity:smoke-matrix": "node scripts/trends-fft-parity-smoke-matrix.mjs",
