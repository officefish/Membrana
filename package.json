    "media:docker:prod:build": "docker compose -f packages/background-media/docker-compose.yml -f deploy/background-media.prod.compose.yml build",
    "media:docker:prod:up": "docker compose -f packages/background-media/docker-compose.yml -f deploy/background-media.prod.compose.yml --env-file /etc/membrana/media.env up -d",
    "media:verify-swagger": "yarn workspace @membrana/background-media verify:swagger",
