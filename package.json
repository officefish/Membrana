{
  "name": "membrana",
  "version": "0.1.0",
  "private": true,
  "description": "Membrana — модульная платформа управления устройствами и расписанием",
  "workspaces": [
    "packages/*",
    "packages/libs/*",
    "packages/services/*",
    "packages/services/detectors/*",
    "apps/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint --concurrency=3",
    "test": "turbo run test --concurrency=3",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "morning-care": "node scripts/morning-care.mjs",
    "anthropic:smoke": "node scripts/anthropic-smoke.mjs",
    "anthropic:task": "node scripts/anthropic-task.mjs",
    "claude:code": "node scripts/claude-code-with-proxy.mjs",
    "code-review": "node scripts/code-review.mjs",
    "save-code-review": "yarn run archive:daily-review",
    "archive:daily-day": "node scripts/archive-daily-day-artifacts.mjs",
    "save-daily-day": "yarn run archive:daily-day",
    "code-review:full": "node scripts/code-review.mjs --full",
    "plan:day": "node scripts/strategic-plan-day.mjs",
    "plan:day:full": "node scripts/strategic-plan-day.mjs --full",
    "plan:week": "node scripts/strategic-plan-week.mjs",
    "plan:week:full": "node scripts/strategic-plan-week.mjs --full",
    "standup": "node scripts/daily-standup.mjs",
    "standup:full": "node scripts/daily-standup.mjs --full",
    "standup:dry": "node scripts/daily-standup.mjs --dry-run",
    "main-day-issue": "node scripts/main-day-issue.mjs",
    "main-day-issue:dry": "node scripts/main-day-issue.mjs --dry-run",
    "main-day-issue:full": "node scripts/main-day-issue.mjs --full",
    "ritual:day": "node scripts/morning-care.mjs && node scripts/strategic-plan-day.mjs && node scripts/daily-standup.mjs && node scripts/main-day-issue.mjs",
    "ritual:evening": "node scripts/archive-daily-day-artifacts.mjs && node scripts/code-review.mjs && node scripts/archive-daily-code-review.mjs",
    "ritual:day:no-api": "node scripts/morning-care.mjs --no-anthropic && node scripts/daily-standup.mjs --dry-run && node scripts/main-day-issue.mjs --allow-missing-standup",
    "analyzers:research:week": "node scripts/analyzers-research-week.mjs",
    "analyzers:research:week:dry": "node scripts/analyzers-research-week.mjs --dry-run",
    "ask": "node scripts/ask-persona.mjs",
    "consilium": "node scripts/consilium.mjs",
    "archive:daily-review": "node scripts/archive-daily-code-review.mjs",
    "test:scripts": "node --test scripts/context-collector-paths.test.mjs scripts/consilium-paths.test.mjs scripts/main-day-issue-paths.test.mjs scripts/daily-standup-paths.test.mjs scripts/task-registry.test.mjs scripts/archive-doc-snapshot.test.mjs",
    "task:list": "node scripts/task-list.mjs",
    "task:sync-readme": "node scripts/task-list.mjs --sync-readme",
    "task:archive": "node scripts/archive-task.mjs",
    "task:close-github": "node scripts/task-close-github-issues.mjs",
    "task:close-github:dry": "node scripts/task-close-github-issues.mjs --dry-run",
    "test:detectors": "turbo run test --filter=@membrana/detector-base --filter=@membrana/harmonic-detector-service --filter=@membrana/cepstral-detector-service --filter=@membrana/spectral-flux-detector-service --filter=@membrana/yamnet-detector-service --filter=@membrana/clap-detector-service --filter=@membrana/agentic-detector-service",
    "lint:detectors": "turbo run lint --filter=@membrana/detector-base --filter=@membrana/harmonic-detector-service --filter=@membrana/cepstral-detector-service --filter=@membrana/spectral-flux-detector-service --filter=@membrana/yamnet-detector-service --filter=@membrana/clap-detector-service --filter=@membrana/agentic-detector-service",
    "office:dev": "yarn workspace @membrana/background-office dev",
    "office:build": "yarn workspace @membrana/background-office build",
    "office:verify-swagger": "yarn workspace @membrana/background-office verify:swagger"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "undici": "^6.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@4.5.0"
}
