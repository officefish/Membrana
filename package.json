    "task:archive": "node scripts/archive-task.mjs",
    "hackathon:close": "node scripts/hackathon-close.mjs",
    "task:close-github": "node scripts/task-close-github-issues.mjs",
    "task:close-github:dry": "node scripts/task-close-github-issues.mjs --dry-run",
    "issues:audit": "node scripts/github-issues-audit.mjs",
    "issues:audit:apply": "node scripts/github-issues-audit.mjs --apply",
