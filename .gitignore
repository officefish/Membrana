# Зависимости
node_modules/

# Сборка
dist/
dist-demo/
build/
apps/membrana-studio/client-dist/
apps/membrana-studio/release/
*.tsbuildinfo
# Инкрементальные кэши TS с суффиксами (клиент: tsconfig.app / tsconfig.node)
**/.tsbuildinfo.*

# Кэш Turbo
.turbo/

# Покрытие тестов
coverage/

# Логи
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Локальные дампы console (см. logs/README.md)
logs/apps/**/*
!logs/**/.gitignore
!logs/**/README.md

# Окружение
.env
.env.local
.env.*.local
**/.env.docker

# Локальные TLS-ключи (не коммитить)
ssl/

# Git worktrees (локальные, не коммитить)
.worktrees/

# MCP (локальные индексы и конфиги с ключами)
.gitnexus/
claude_desktop_config.json
docs/discussions/mcp-tier0.generated.json

# RAG (@membrana/rag-service) — LanceDB index + hash manifest (local only)
.membrana/rag/

# Редакторы
.idea/
*.swp
.DS_Store
Thumbs.db

# Временные файлы
*.tmp
*.temp

# Случайный emit tsc в src (outDir должен быть dist/)
packages/services/detectors/**/src/*.js
packages/services/detectors/**/src/*.js.map
packages/services/detectors/**/src/*.d.ts
packages/services/detectors/**/src/*.d.ts.map

# Локальные SSH/debug-скрипты и вывод (не коммитить)
scripts/_ssh-*.mjs
scripts/_*-out.txt

# Локальные логи deploy/recover в корне (Tee-Object при отладке VPS)
/cabinet-recover*.txt
/deploy-*.txt
/prod-check.txt

# Кэш загрузки внешних датасетов (WAV остаются в real-collection/)
docs/datasets/samples/.cache/

# Lockfile-ы других пакетных менеджеров (используем yarn.lock)
package-lock.json
pnpm-lock.yaml

# Yarn 4 (Berry) — служебные файлы.
# yarn.lock мы коммитим, всё остальное — нет.
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# claude / cursor / continue — локальные каталоги AI IDE (не коммитить)
.claude/*
!.claude/CLAUDE.md
!.claude/skills/
!.claude/skills/**
!.claude/agents/
!.claude/agents/**
.continue/
.cursor/mcp.json

# SSL сертификаты для https соединений
ssl/

# LLM proxy secret (локальный, не коммитить никогда)
.env.llm-proxy
.env.llm-proxy.local

# Playwright / тестовые артефакты клиента
apps/client/playwright-report/
apps/client/test-results/

# Локальный дамп sync-readme (96 КБ, временный)
.sync-readme-out.txt

# Локальные бинари агентных инструментов (не коммитить)
tools/bin/*.exe
tools/bin/*.zip

# Vite HMR/esbuild временные конфиги (регенерируются; блокировали deploy preflight)
*.timestamp-*.mjs

# Python bytecode-кэш скриптов
__pycache__/
*.pyc

# Артефакт code-review --uncommitted (перезаписывается каждым прогоном → autostash-трение)
docs/discussions/uncommitted-code-review.md

# Артефакт yarn hermes:brief (генерируемый снимок состояния сессии, перезаписывается)
docs/HERMES_BRIEF.md

# Журнал drift-anchor (DA3 дайджесты + DA4/DA5 записи якорей) — локальный артефакт хоста (office/CI), не для репо
docs/reports/drift-anchor/
