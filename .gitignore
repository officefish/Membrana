# Зависимости
node_modules/

# Сборка
dist/
dist-demo/
build/
apps/membrana-studio/client-dist/
apps/membrana-studio/release/
*.tsbuildinfo
# Инкрементальные кэши TS с суффиксами (клиент: tsconfig.app / tsconfig.node)
**/.tsbuildinfo.*

# Кэш Turbo
.turbo/

# Покрытие тестов
coverage/

# Логи
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Окружение
.env
.env.local
.env.*.local
**/.env.docker

# Локальные TLS-ключи (не коммитить)
ssl/

# MCP (локальные индексы и конфиги с ключами)
.gitnexus/
claude_desktop_config.json
docs/discussions/mcp-tier0.generated.json

# Редакторы
.idea/
*.swp
.DS_Store
Thumbs.db

# Временные файлы
*.tmp
*.temp

# Случайный emit tsc в src (outDir должен быть dist/)
packages/services/detectors/**/src/*.js
packages/services/detectors/**/src/*.js.map
packages/services/detectors/**/src/*.d.ts
packages/services/detectors/**/src/*.d.ts.map

# Локальные SSH/debug-скрипты и вывод (не коммитить)
scripts/_ssh-*.mjs
scripts/_*-out.txt

# Локальные логи deploy/recover в корне (Tee-Object при отладке VPS)
/cabinet-recover*.txt
/deploy-*.txt
/prod-check.txt

# Кэш загрузки внешних датасетов (WAV остаются в real-collection/)
docs/datasets/samples/.cache/

# Lockfile-ы других пакетных менеджеров (используем yarn.lock)
package-lock.json
pnpm-lock.yaml

# Yarn 4 (Berry) — служебные файлы.
# yarn.lock мы коммитим, всё остальное — нет.
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*

# claude / cursor / continue mcp servers settings
.claude/claude_code_config.json
.cursor/mcp.json
.continue/config.json
