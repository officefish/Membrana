# Зависимости
node_modules/

# Сборка
dist/
dist-demo/
build/
*.tsbuildinfo
# Инкрементальные кэши TS с суффиксами (клиент: tsconfig.app / tsconfig.node)
**/.tsbuildinfo.*

# Кэш Turbo
.turbo/

# Покрытие тестов
coverage/

# Логи
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Окружение
.env
.env.local
.env.*.local

# MCP (локальные индексы и конфиги с ключами)
.gitnexus/
claude_desktop_config.json
docs/discussions/mcp-tier0.generated.json

# Редакторы
.idea/
*.swp
.DS_Store
Thumbs.db

# Временные файлы
*.tmp
*.temp

# Lockfile-ы других пакетных менеджеров (используем yarn.lock)
package-lock.json
pnpm-lock.yaml

# Yarn 4 (Berry) — служебные файлы.
# yarn.lock мы коммитим, всё остальное — нет.
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.pnp.*
