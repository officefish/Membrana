{
  "name": "@membrana/background-office",
  "version": "0.1.0",
  "private": true,
  "description": "Централизованный HTTP-шлюз к внешним API Membrana (Claude, Linear, webhooks).",
  "main": "./dist/main.js",
  "scripts": {
    "prepare": "node ./scripts/copy-prompts.cjs",
    "build": "yarn prepare && tsc -b",
    "dev": "yarn prepare && node --watch -r ts-node/register ./src/main.ts",
    "start": "node ./dist/main.js",
    "clean": "rimraf dist .turbo .tsbuildinfo",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "yarn prepare && vitest run",
    "self-check": "tsx ./src/cli/outbound-self-check.ts",
    "verify:swagger": "yarn build && node scripts/verify-swagger.mjs"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@membrana/rag-service": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/schedule": "^5.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@octokit/rest": "^21.0.2",
    "dotenv": "^16.4.5",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
