PORT=3000
NODE_ENV=development
LOG_LEVEL=info

API_INTERNAL_TOKEN=change-me

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=

GITHUB_TOKEN=
GITHUB_OWNER=officefish
GITHUB_REPO=Membrana

# Опционально, если Anthropic из терминала без системного VPN:
# HTTPS_PROXY=http://127.0.0.1:7890

# Telegram ally reports (#428): дайджесты ритуалов в приватную группу союзников
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLY_CHAT_ID=

# Night Hunt (optional scheduled jobs → GitHub PR via OpenRouter)
# NIGHT_HUNT_ENABLED=true
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# NIGHT_HUNT_BASE_BRANCH=main

# DeepSeek direct — fallback нарратива ночных агентов (ADR 0005), без прокси
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Panel auth (OP2, эпик #438) — stateless-авторизация panel.mmbrn.tech
# PANEL_SESSION_SECRET=          # обязателен для входа; подпись cookie/state
# PANEL_INVITE_SECRET=           # опционально (fallback = PANEL_SESSION_SECRET)
# PANEL_GITHUB_CLIENT_ID=        # GitHub OAuth App (operator/owner)
# PANEL_GITHUB_CLIENT_SECRET=
# PANEL_GITHUB_ALLOWLIST={"github_user_id":"owner"}
# PANEL_PUBLIC_URL=https://panel.mmbrn.tech
# PANEL_RATE_LIMIT_PER_MIN=120     # rate-limit панельных ручек на клиента (OP5)
