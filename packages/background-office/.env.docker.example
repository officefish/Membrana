# Docker Compose stack (@membrana/background-office)
# cp .env.docker.example .env.docker
# yarn office:docker:up

# Host port (container listens on 3000)
OFFICE_PORT=3000

PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# API auth — same value clients send as X-Membrana-Token
API_INTERNAL_TOKEN=change-me-in-production

# Required integrations — placeholders allow /health without real keys.
# Replace with real values for POST /v1/claude/ask smoke.
ANTHROPIC_API_KEY=docker-placeholder-not-for-api
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

LINEAR_API_KEY=docker-placeholder
LINEAR_WEBHOOK_SECRET=docker-placeholder

GITHUB_TOKEN=docker-placeholder
GITHUB_OWNER=officefish
GITHUB_REPO=Membrana
