PORT=3010
NODE_ENV=development
LOG_LEVEL=info

API_INTERNAL_TOKEN=dev-token-change-me

DATABASE_URL=postgresql://membrana:membrana@localhost:5433/membrana_media
MEDIA_BLOB_DIR=./data/blobs
MEDIA_USER_STORAGE_QUOTA_BYTES_PER_DEVICE=1073741824
MEDIA_BUFFER_QUOTA_BYTES_PER_DEVICE=1073741824
MEDIA_DEFAULT_DATASET_CATALOG_ID=free-v1-catalog
MAX_UPLOAD_BYTES=52428800
MEDIA_ALLOWED_MIME=audio/wav,audio/wave,audio/mpeg,audio/flac,audio/ogg

# Swagger UI at /docs and OpenAPI at /docs-json (default: on in development, off in production)
# SWAGGER_ENABLED=true
