# Docker Compose stack (@membrana/background-media)
# cp .env.docker.example .env.docker
# yarn media:docker:up

# Host port for media API (container always listens on 3010)
MEDIA_PORT=3010

# PostgreSQL (service name: postgres)
POSTGRES_USER=membrana
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=membrana_media

# API auth — same value clients send as X-Membrana-Token
API_INTERNAL_TOKEN=change-me-in-production

LOG_LEVEL=info
MEDIA_QUOTA_BYTES_PER_DEVICE=1073741824
MAX_UPLOAD_BYTES=52428800
MEDIA_ALLOWED_MIME=audio/wav,audio/wave,audio/mpeg,audio/flac,audio/ogg

# Browser origins for apps/client paired mode (comma-separated)
CLIENT_CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# Prod only (deploy/background-media.prod.compose.yml):
# MEDIA_BLOB_HOST_DIR=/var/lib/membrana/media-blobs
