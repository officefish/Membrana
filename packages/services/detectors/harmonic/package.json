{
  "name": "@membrana/harmonic-detector-service",
  "version": "0.1.0",
  "description": "Гармонический портрет мультиротора.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "clean": "rimraf dist dist-demo .turbo .tsbuildinfo",
    "dev:demo": "vite --config demo/vite.config.ts",
    "lint": "eslint src demo --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run src/detector.integration.test.ts"
  },
  "dependencies": {
    "@membrana/audio-engine-service": "*",
    "@membrana/core": "*",
    "@membrana/detector-base": "*",
    "@membrana/fft-analyzer-service": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "daisyui": "^4.12.10",
    "eslint": "^8.57.0",
    "postcss": "^8.4.39",
    "rimraf": "^5.0.0",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^1.4.0"
  }
}
