generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NodeAccessKeyDuration {
  hours_4
  days_3
  weeks_2
  month_1
  months_3
}

enum UserRole {
  admin
  user
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  login        String     @unique
  passwordHash String
  role         UserRole   @default(user)
  createdAt    DateTime   @default(now())
  sessions     Session[]
  membrane     Membrane?
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  scenarioEditLeases NodeScenarioEditLease[]
  deviceCaptures     NodeDeviceCapture[]

  @@index([userId])
  @@index([expiresAt])
}

model Tariff {
  id                     String     @id
  name                   String
  /** Total bytes user may store across their collections on the server (paired mode). */
  userStorageQuotaBytes  BigInt
  /** Live recording buffer capacity; larger buffer supports more concurrent devices. */
  bufferQuotaBytes       BigInt
  /** Read-only system dataset catalog id provisioned for this tariff (not a byte quota). */
  datasetCatalogId       String
  maxActiveKeysPerNode   Int        @default(1)
  /** Max paired nodes a membrane on this tariff may hold (MP7b multi-node). */
  maxNodesPerMembrane    Int        @default(1)
  /** Max editable device-board user workspaces per deviceId (U10). */
  maxUserWorkspaces      Int        @default(3)
  createdAt              DateTime   @default(now())
  membranes              Membrane[]
}

model Membrane {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tariffId  String
  tariff    Tariff   @relation(fields: [tariffId], references: [id])
  nodes     Node[]
  reports   TelemetryReport[]
  liveRecords TelemetryLiveRecord[]
  scenarioEditLeases NodeScenarioEditLease[]
  deviceCaptures     NodeDeviceCapture[]
  createdAt DateTime @default(now())

  @@index([tariffId])
}

model Node {
  id         String          @id @default(uuid()) @db.Uuid
  membraneId String          @db.Uuid
  membrane   Membrane        @relation(fields: [membraneId], references: [id], onDelete: Cascade)
  label      String
  accessKeys NodeAccessKey[]
  device     Device?
  scenarioEditLease NodeScenarioEditLease?
  deviceCapture     NodeDeviceCapture?
  createdAt  DateTime        @default(now())

  @@index([membraneId])
}

model Device {
  id                   String   @id @default(uuid()) @db.Uuid
  nodeId               String   @unique @db.Uuid
  node                 Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  mediaDeviceId        String   @unique @db.Uuid
  label                String?
  pairedKeyId          String?  @db.Uuid
  /** PL2: статус сопряжения. pairedKeyId сохраняем для истории/диагностики. */
  pairingStatus        DevicePairingStatus @default(paired)
  /** Last pairing session token — invalidated when access key is revoked. */
  lastPairSessionToken String?  @unique
  pairedAt             DateTime @default(now())
  lastSeenAt           DateTime @default(now())

  @@index([mediaDeviceId])
  @@index([pairedKeyId])
}

/** PL2 (pairing-lifecycle): жизненный цикл сопряжения устройства с ключом. */
enum DevicePairingStatus {
  paired
  revoked
  unpaired
}

model NodeAccessKey {
  id         String                @id @default(uuid()) @db.Uuid
  nodeId     String                @db.Uuid
  node       Node                  @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  secretHash String
  duration   NodeAccessKeyDuration
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime              @default(now())

  @@index([nodeId])
  @@index([expiresAt])
}

enum TelemetryLiveStatus {
  active
  ended
}

/** Completed analysis snapshot uploaded from paired client (shared render payload). */
model TelemetryReport {
  id            String   @id @default(uuid()) @db.Uuid
  membraneId    String   @db.Uuid
  membrane      Membrane @relation(fields: [membraneId], references: [id], onDelete: Cascade)
  nodeId        String?  @db.Uuid
  mediaDeviceId String?  @db.Uuid
  reportKind    String
  moduleId      String?
  moduleName    String?
  clientEntryId String?
  finishedAt    DateTime
  payload       Json
  tags          String[] @default([])
  createdAt     DateTime @default(now())

  @@index([membraneId, finishedAt(sort: Desc)])
  @@unique([membraneId, clientEntryId])
}

/** Active or recent live telemetry session from paired client. */
model TelemetryLiveRecord {
  id             String              @id @default(uuid()) @db.Uuid
  membraneId     String              @db.Uuid
  membrane       Membrane            @relation(fields: [membraneId], references: [id], onDelete: Cascade)
  nodeId         String?             @db.Uuid
  mediaDeviceId  String?             @db.Uuid
  recordKind     String
  moduleId       String?
  clientRecordId String?
  status         TelemetryLiveStatus @default(active)
  startedAt      DateTime
  endedAt        DateTime?
  payload        Json
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([membraneId, status, startedAt(sort: Desc)])
  @@unique([membraneId, clientRecordId])
}

/** Server-first edit lease: один holder cabinet на (membraneId, mediaDeviceId). */
enum DeviceCaptureMode {
  soft
  hard
}

/// Явный захват устройства кабинетом (tariff v2, канон DEVICE_BOARD_SERVER_FIRST.md v2.0).
model NodeDeviceCapture {
  id            String            @id @default(uuid()) @db.Uuid
  membraneId    String            @db.Uuid
  membrane      Membrane          @relation(fields: [membraneId], references: [id], onDelete: Cascade)
  nodeId        String            @unique @db.Uuid
  node          Node              @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  mediaDeviceId String            @db.Uuid
  sessionId     String            @db.Uuid
  session       Session           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  mode          DeviceCaptureMode
  acquiredAt    DateTime          @default(now())
  expiresAt     DateTime
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([membraneId, mediaDeviceId])
  @@index([expiresAt])
}

model NodeScenarioEditLease {
  id            String   @id @default(uuid()) @db.Uuid
  membraneId    String   @db.Uuid
  membrane      Membrane @relation(fields: [membraneId], references: [id], onDelete: Cascade)
  nodeId        String   @unique @db.Uuid
  node          Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  mediaDeviceId String   @db.Uuid
  sessionId     String   @db.Uuid
  session       Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  revision      Int      @default(0)
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([membraneId, mediaDeviceId])
  @@index([expiresAt])
}

/**
 * TD2 (tech-debt-2026-07): персистентный список сценариев + выбор — переживает
 * рестарт сервера (ранее in-memory Map в DeviceScenarioRegistry терялся на рестарте).
 * Тела сценариев НЕ храним (пользовательские, живут на устройстве) — только список
 * {id,title} (scenarios Json) + выбранный id. Ключ — mediaDeviceId (не FK: реестр
 * ведёт себя как авторитетный снапшот-кэш, независимый от жизненного цикла Device).
 */
model NodeScenarioSelection {
  mediaDeviceId      String   @id
  membraneId         String   @db.Uuid
  scenarios          Json
  selectedScenarioId String?
  updatedAt          DateTime @updatedAt
}
