PORT=3020
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL (dev: yarn cabinet:db:up)
DATABASE_URL=postgresql://membrana:membrana@localhost:5434/membrana_cabinet

# Shared secret for service-to-service /v1/* (pairing, media bridge — MP3+)
API_INTERNAL_TOKEN=change-me-cabinet-internal

# Session lifetime for login/password auth
SESSION_TTL_HOURS=168

# Comma-separated origins for apps/cabinet (dev)
CABINET_CORS_ORIGINS=http://localhost:5174

# Allow POST /v1/auth/register (default: true in development)
ALLOW_REGISTRATION=true
