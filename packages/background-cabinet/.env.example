PORT=3020
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL (dev: yarn cabinet:db:up)
DATABASE_URL=postgresql://membrana:membrana@localhost:5434/membrana_cabinet

# Shared secret for service-to-service /v1/* (pairing, media bridge — MP3+)
API_INTERNAL_TOKEN=change-me-cabinet-internal

# Session lifetime for login/password auth
SESSION_TTL_HOURS=168

# Comma-separated origins for apps/cabinet (dev)
CABINET_CORS_ORIGINS=http://localhost:5174

# Comma-separated origins for apps/client pairing (MP3)
CLIENT_CORS_ORIGINS=http://localhost:5173

# background-media internal URL (cabinet → media service calls)
MEDIA_API_URL=http://localhost:3010
# Public URL returned to apps/client in POST /v1/pair (defaults to MEDIA_API_URL)
# MEDIA_PUBLIC_API_URL=https://media.membrana.space
# Defaults to API_INTERNAL_TOKEN when unset
# MEDIA_API_TOKEN=change-me-media-internal

# Allow POST /v1/auth/register (default: true in development)
ALLOW_REGISTRATION=true
