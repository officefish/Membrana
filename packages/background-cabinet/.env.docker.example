# Docker Compose stack (@membrana/background-cabinet + cabinet-web)
# cp .env.docker.example .env.docker
# yarn cabinet:docker:up

CABINET_API_PORT=3020
CABINET_WEB_PORT=8080

POSTGRES_USER=membrana
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=membrana_cabinet

API_INTERNAL_TOKEN=change-me-in-production
SESSION_TTL_HOURS=168
CABINET_CORS_ORIGINS=http://localhost:8080,http://localhost:5174
CLIENT_CORS_ORIGINS=http://localhost:5173
MEDIA_API_URL=http://host.docker.internal:3010
# MEDIA_API_TOKEN=defaults to API_INTERNAL_TOKEN
ALLOW_REGISTRATION=true
CABINET_RUN_SEED=true
CABINET_BOOTSTRAP_LOGIN=demo
CABINET_BOOTSTRAP_PASSWORD=demo12345

# SPA build arg (cabinet-web image)
VITE_CABINET_API_URL=http://localhost:3020
