{
  "name": "@membrana/background-cabinet",
  "version": "0.1.0",
  "private": true,
  "description": "Identity and domain API: users, sessions, membranes, nodes, keys (MP1–MP2).",
  "main": "./dist/main.js",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "build": "prisma generate && tsc -b",
    "dev": "node --watch -r ts-node/register ./src/main.ts",
    "start": "node ./dist/main.js",
    "clean": "rimraf dist .turbo .tsbuildinfo",
    "lint": "eslint src --ext .ts",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "prisma generate && vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@membrana/core": "*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/platform-ws": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prisma": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.13",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
