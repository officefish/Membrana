{
  "name": "@membrana/device-board",
  "version": "0.1.0",
  "description": "Модуль управления устройствами: учёт, состояние, телеметрия.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist .turbo .tsbuildinfo",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui --passWithNoTests"
  },
  "dependencies": {
    "@membrana/core": "*"
  },
  "devDependencies": {
    "@vitest/ui": "^1.4.0",
    "eslint": "^8.57.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
