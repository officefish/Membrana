{
  "name": "@membrana/device-board",
  "version": "0.1.0",
  "description": "Визуальный граф обработки сигнала (нод-доска): view-only UI на @xyflow/react поверх MembranaRegistry и shared-хабов.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist .turbo .tsbuildinfo",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@membrana/core": "*",
    "@xyflow/react": "^12.11.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
