{
  "$schema": "https://opencode.ai/config.json",
  "$comment": "Membrana experimental OpenCode. Запуск: yarn opencode:membrana",
  "plugin": ["opencode-fallback", "@azumag/opencode-rate-limit-fallback"],
  "enabled_providers": ["freemodel", "openrouter", "ollama"],
  "model": "freemodel/claude-sonnet-4-6",
  "small_model": "openrouter/anthropic/claude-haiku-4.5",
  "default_agent": "plan",
  "provider": {
    "freemodel": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "FreeModel.dev (OpenAI format)",
      "options": {
        "baseURL": "https://api.freemodel.dev/v1",
        "apiKey": "{env:FREEMODEL_DEV_API_KEY}"
      },
      "models": {
        "claude-haiku-4-5-20251001": {
          "name": "Claude Haiku 4.5",
          "limit": { "context": 200000, "output": 64000 }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": { "context": 1000000, "output": 64000 }
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7",
          "limit": { "context": 1000000, "output": 128000 }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 mini"
        }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter (fallback)",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}",
        "headers": {
          "HTTP-Referer": "https://github.com/officefish/Membrana",
          "X-Title": "Membrana OpenCode experimental"
        }
      },
      "models": {
        "anthropic/claude-haiku-4.5": {
          "name": "Claude Haiku 4.5 (OR)",
          "limit": { "context": 200000, "output": 64000 }
        },
        "anthropic/claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6 (OR)",
          "limit": { "context": 200000, "output": 64000 }
        },
        "anthropic/claude-opus-4.7": {
          "name": "Claude Opus 4.7 (OR)",
          "limit": { "context": 200000, "output": 64000 }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "{env:OLLAMA_HOST}/v1",
        "apiKey": "ollama"
      },
      "models": {
        "mistral:7b": {
          "name": "Mistral 7B local"
        }
      }
    }
  },
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "."],
      "enabled": true,
      "timeout": 10000
    },
    "git": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/mcp-server-git", "--repository", "."],
      "enabled": true,
      "timeout": 10000
    },
    "perplexity": {
      "type": "local",
      "command": ["npx", "-y", "@perplexity-ai/mcp-server"],
      "enabled": true,
      "timeout": 15000,
      "environment": {
        "PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}"
      }
    }
  },
  "agent": {
    "plan": {
      "mode": "primary",
      "model": "openrouter/anthropic/claude-haiku-4.5",
      "description": "Read-only exploration (OpenRouter primary when FreeModel unstable)",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "build": {
      "mode": "primary",
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "description": "Implementation agent with proxy fallback chain",
      "permission": {
        "edit": "allow",
        "bash": "ask"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask"
  }
}
