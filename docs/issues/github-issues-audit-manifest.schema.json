{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://membrana.local/schemas/github-issues-audit-manifest.json",
  "title": "GitHub Issues Audit Manifest",
  "type": "object",
  "required": ["version", "auditDate", "closed", "open"],
  "properties": {
    "version": { "const": 1 },
    "auditDate": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "branch": { "type": "string" },
    "headSha": { "type": "string" },
    "turbo": {
      "type": "object",
      "properties": {
        "result": { "type": "string" },
        "exitCode": { "type": "integer" }
      }
    },
    "coordinator": { "type": "string", "default": "Vesnin" },
    "notes": { "type": "string" },
    "closed": {
      "type": "array",
      "items": { "$ref": "#/$defs/closedItem" }
    },
    "open": {
      "type": "array",
      "items": { "$ref": "#/$defs/openItem" }
    }
  },
  "$defs": {
    "closedItem": {
      "type": "object",
      "required": ["number", "reason", "persona", "summary", "comment"],
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "reason": { "enum": ["completed", "not planned"] },
        "persona": { "type": "string" },
        "summary": { "type": "string", "maxLength": 200 },
        "comment": { "type": "string" },
        "registryId": { "type": ["string", "null"] }
      }
    },
    "openItem": {
      "type": "object",
      "required": ["number", "priority", "persona", "summary"],
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "priority": {
          "enum": ["important", "recommended", "not-urgent", "optional"]
        },
        "persona": { "type": "string" },
        "summary": { "type": "string", "maxLength": 200 },
        "registryId": { "type": ["string", "null"] }
      }
    }
  }
}
