{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://membrana.local/schemas/task-archive-log.schema.json",
  "title": "Membrana task archive JSONL record",
  "type": "object",
  "required": ["id", "title", "status", "archivedAt", "archiveSchemaVersion"],
  "additionalProperties": true,
  "properties": {
    "archiveSchemaVersion": { "type": "number", "const": 1 },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "promptPath": { "type": ["string", "null"] },
    "githubIssue": { "type": ["number", "null"] },
    "linearId": { "type": ["string", "null"] },
    "size": { "type": "string" },
    "status": { "type": "string", "const": "archived" },
    "createdAt": { "type": ["string", "null"] },
    "archivedAt": { "type": "string" },
    "archiveNotes": { "type": ["string", "null"] },
    "githubIssueClosedAt": { "type": ["string", "null"] },
    "resolution": { "type": ["string", "null"] }
  }
}
