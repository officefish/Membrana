{
  "name": "@membrana/docs",
  "version": "0.1.0",
  "private": true,
  "description": "Membrana product documentation (Mintlify). Autonomous from apps/client.",
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "dev": "node ../../scripts/docs-dev.mjs",
    "build": "node ../../scripts/verify-mintlify-docs.mjs",
    "lint": "node ../../scripts/verify-mintlify-docs.mjs --links",
    "clean": "rimraf .mintlify",
    "typecheck": "echo \"@membrana/docs: no TypeScript\"",
    "test": "echo \"@membrana/docs: no unit tests\""
  },
  "devDependencies": {
    "mintlify": "^4.2.123",
    "rimraf": "^5.0.0"
  }
}
