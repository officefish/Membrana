{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./.tsbuildinfo.app",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,

    "paths": {
      "@membrana/core": ["../../packages/core/src/index.ts"],
      "@membrana/core/*": ["../../packages/core/src/*"],
      "@membrana/agenda": ["../../packages/agenda/src/index.ts"],
      "@membrana/agenda/*": ["../../packages/agenda/src/*"],
      "@membrana/device-board": ["../../packages/device-board/src/index.ts"],
      "@membrana/device-board/*": ["../../packages/device-board/src/*"],
      "@membrana/sample-playback-service": ["../../packages/services/sample-playback/src/index.ts"],
      "@membrana/sample-playback-service/*": ["../../packages/services/sample-playback/src/*"],
      "@membrana/audio-engine-service": ["../../packages/services/audio-engine/src/index.ts"],
      "@membrana/audio-engine-service/*": ["../../packages/services/audio-engine/src/*"],
      "@membrana/fft-analyzer-service": ["../../packages/services/fft-analyzer/src/index.ts"],
      "@membrana/fft-analyzer-service/*": ["../../packages/services/fft-analyzer/src/*"],
      "@membrana/telemetry-service": ["../../packages/services/telemetry/src/index.ts"],
      "@membrana/telemetry-service/*": ["../../packages/services/telemetry/src/*"],
      "@membrana/audio-data-viz": ["../../packages/libs/audioDataViz/src/index.ts"],
      "@membrana/audio-data-viz/*": ["../../packages/libs/audioDataViz/src/*"],
      "@membrana/detector-base": ["../../packages/services/detectors/base/src/index.ts"],
      "@membrana/detector-base/*": ["../../packages/services/detectors/base/src/*"],
      "@membrana/harmonic-detector-service": ["../../packages/services/detectors/harmonic/src/index.ts"],
      "@membrana/harmonic-detector-service/*": ["../../packages/services/detectors/harmonic/src/*"],
      "@membrana/cepstral-detector-service": ["../../packages/services/detectors/cepstral/src/index.ts"],
      "@membrana/cepstral-detector-service/*": ["../../packages/services/detectors/cepstral/src/*"],
      "@membrana/spectral-flux-detector-service": ["../../packages/services/detectors/spectral-flux/src/index.ts"],
      "@membrana/spectral-flux-detector-service/*": ["../../packages/services/detectors/spectral-flux/src/*"],
      "@membrana/template-match-detector-service": ["../../packages/services/detectors/template-match/src/index.ts"],
      "@membrana/template-match-detector-service/*": ["../../packages/services/detectors/template-match/src/*"],
      "@membrana/trends-detector-service": ["../../packages/services/trends-detector/src/index.ts"],
      "@membrana/trends-detector-service/*": ["../../packages/services/trends-detector/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"],
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/agenda" },
    { "path": "../../packages/device-board" },
    { "path": "../../packages/services/audio-engine" },
    { "path": "../../packages/services/fft-analyzer" },
    { "path": "../../packages/services/sample-playback" },
    { "path": "../../packages/services/telemetry" },
    { "path": "../../packages/libs/audioDataViz" },
    { "path": "../../packages/services/detectors/base" },
    { "path": "../../packages/services/detectors/harmonic" },
    { "path": "../../packages/services/detectors/cepstral" },
    { "path": "../../packages/services/detectors/spectral-flux" },
    { "path": "../../packages/services/detectors/template-match" },
    { "path": "../../packages/services/trends-detector" }
  ]
}
