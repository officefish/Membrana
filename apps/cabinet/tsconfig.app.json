{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./.tsbuildinfo.app",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@membrana/core": ["../../packages/core/src/index.ts"],
      "@membrana/core/*": ["../../packages/core/src/*"],
      "@membrana/media-library-service": ["../../packages/services/media-library/src/index.ts"],
      "@membrana/media-library-service/*": ["../../packages/services/media-library/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"]
}
