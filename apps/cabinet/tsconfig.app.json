{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "tsBuildInfoFile": "./.tsbuildinfo.app",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@membrana/core": ["../../packages/core/src/index.ts"],
      "@membrana/core/*": ["../../packages/core/src/*"],
      "@membrana/media-library-service": ["../../packages/services/media-library/src/index.ts"],
      "@membrana/media-library-service/*": ["../../packages/services/media-library/src/*"],
      "@membrana/sample-playback-service": ["../../packages/services/sample-playback/src/index.ts"],
      "@membrana/sample-playback-service/*": ["../../packages/services/sample-playback/src/*"],
      "@membrana/audio-engine-service": ["../../packages/services/audio-engine/src/index.ts"],
      "@membrana/audio-engine-service/*": ["../../packages/services/audio-engine/src/*"],
      "@membrana/detector-report": ["../../packages/libs/detector-report/src/index.ts"],
      "@membrana/detector-report/*": ["../../packages/libs/detector-report/src/*"],
      "@membrana/journal-report-views": ["../../packages/libs/journal-report-views/src/index.ts"],
      "@membrana/journal-report-views/*": ["../../packages/libs/journal-report-views/src/*"],
      "@membrana/trends-detector-service": ["../../packages/services/trends-detector/src/index.ts"],
      "@membrana/trends-detector-service/*": ["../../packages/services/trends-detector/src/*"],
      "@membrana/telemetry-journal-service": ["../../packages/services/telemetry-journal/src/index.ts"],
      "@membrana/telemetry-journal-service/*": ["../../packages/services/telemetry-journal/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.test.tsx"],
  "references": [
    { "path": "../../packages/core" },
    { "path": "../../packages/services/audio-engine" },
    { "path": "../../packages/services/sample-playback" },
    { "path": "../../packages/services/media-library" },
    { "path": "../../packages/services/telemetry-journal" },
    { "path": "../../packages/services/trends-detector" },
    { "path": "../../packages/libs/detector-report" },
    { "path": "../../packages/libs/journal-report-views" }
  ]
}
