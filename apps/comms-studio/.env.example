# apps/comms-studio/.env.example — изолированный env контура коммуникаций (CC4).
#
# Реальный apps/comms-studio/.env игнорируется git (см. корневой .gitignore) и НЕ пересекается
# с продуктовым скоупом секретов. Контур — сток, не исток: секреты сюда попадать не должны;
# secret-scan (yarn workspace @membrana/comms-studio secret-scan) блокирует их в out/ и src/.
#
# Скопируйте в apps/comms-studio/.env и заполните плейсхолдеры (без реальных секретов в git).

# Каталог экспорта выхода контура для партнёра (по умолчанию — out/).
COMMS_OUT_DIR=out

# (опционально) Идентификатор папки Google Drive для ручной выгрузки партнёром.
# Только не-секретный идентификатор; токены доступа — вне git и вне этого файла.
COMMS_DRIVE_FOLDER_ID=
