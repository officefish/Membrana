# Caddy v2 — Membrane cabinet (MP1).
# Copy to VPS: /etc/caddy/Caddyfile.d/cabinet.caddy
# Replace domains if needed, then: sudo systemctl reload caddy
#
# API routes on the same host as SPA (no extra DNS). Optional dedicated API host
# below when cabinet-api.* A-record exists.

cabinet.membrana.space {
	encode gzip

	handle /health* {
		reverse_proxy 127.0.0.1:3020
	}
	handle /v1/* {
		reverse_proxy 127.0.0.1:3020
	}
	handle {
		reverse_proxy 127.0.0.1:8080
	}
}

# Uncomment after DNS A-record for cabinet-api.* points to VPS:
# cabinet-api.membrana.space {
# 	encode gzip
# 	reverse_proxy 127.0.0.1:3020
# }
