# Скопируйте в `.env` и подставьте значения. Файл `.env` в репозитории не коммитится.
# Ключ API: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Если VPN не трогает терминал (403 от Anthropic) — прокси локального клиента (Clash / v2rayN и т.д.):
# HTTPS_PROXY=http://127.0.0.1:7890
# (порт смотрите в настройках «HTTP proxy» / Mixed port.)
# При таймаутах connect в Node/undici (Windows+прокси): ANTHROPIC_CONNECT_TIMEOUT_MS=120000
# Большие запросы (plan:day, standup) обрывает прокси — прямой доступ: ANTHROPIC_NO_PROXY=1

# Опционально: модель для `yarn code-review`, `yarn anthropic:smoke`, `yarn anthropic:task`
# (по умолчанию в scripts/_anthropic-env.mjs — claude-haiku-4-5-20251001).
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Локальные проверки (из корня репозитория):
#   yarn anthropic:smoke   — один короткий запрос к API
#   yarn morning-care      — утренняя проверка: прокси (TCP), git, node --test, затем anthropic:smoke-подобный запрос
#   yarn morning-care --no-anthropic  — то же без вызова API
#   yarn anthropic:task    — разбор docs/ARCHITECTURE.md в стиле чеклиста PR
#   yarn archive:daily-day — вечер: снимок STRATEGIC_PLAN_DAY + DAILY_STANDUP + MAIN_DAY_ISSUE → docs/archive/daily-day/
#   yarn code-review       — полный обзор → docs/DAILY_CODE_REVIEW.md (нужен ключ; после archive:daily-day)
#   yarn plan:day          — план на следующий день  → docs/STRATEGIC_PLAN_DAY.md
#   yarn plan:week         — план на следующую неделю → docs/STRATEGIC_PLAN_WEEK.md
#   yarn standup           — ежедневный стендап (сводка review + план + issues + temp) → docs/DAILY_STANDUP.md
#   yarn standup:dry       — только собрать контекст стендапа, без API
#   Утро: yarn ritual:day   Вечер: yarn ritual:evening (archive:daily-day → code-review → save-code-review)
# Оба plan-скрипта опираются на docs/WHITE_PAPER.md и git log за период;
# доступны флаги --full и --since="<git --since>".
# Недельный план дополнительно подмешивает docs/WEEKLY_ANALYZERS_RESEARCH.md, если файл есть.
#
#   yarn analyzers:research:week        — еженедельный «радар» новых аналайзеров (HF Hub + arXiv)
#                                         → docs/WEEKLY_ANALYZERS_RESEARCH.md (перезаписывается).
#   yarn analyzers:research:week:dry    — то же, но без вызова Anthropic (для отладки сети/промпта).
# Радар учитывается недельным планировщиком и НЕ учитывается ежедневным code-review.
#
#   yarn ask <persona> "<вопрос>"   — спросить совета у виртуального члена команды.
# Персонажи: vesnin (Teamlead), dynin (Математик).
# Часто:    yarn ask vesnin --gh-issue 12 "вопрос"
# Доп.:     --ticket-file <path>, --task "<text>", --save-as <name>, --no-save, --no-context.
# Ответ дублируется в docs/discussions/<name>.md (append) при --gh-issue / --ticket-file / --save-as.
# Шаг 2: централизованный сервер `yarn office:dev` / `packages/background-office` (Linear + webhooks + persona API).

# --- Пакет @membrana/background-office (HTTP-шлюз внешних API) ---
# См. packages/background-office/README.md и packages/background-office/.env.example
# PORT=3000
# NODE_ENV=development
# LOG_LEVEL=info
# API_INTERNAL_TOKEN=
# LINEAR_API_KEY=
# LINEAR_WEBHOOK_SECRET=
# GITHUB_TOKEN=
# GITHUB_OWNER=officefish
# GITHUB_REPO=Membrana
