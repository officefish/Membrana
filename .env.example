# Скопируйте в `.env` и подставьте значения. Файл `.env` в репозитории не коммитится.
# Ключ API: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Если VPN не трогает терминал (403 от Anthropic) — прокси локального клиента (Clash / v2rayN и т.д.):
# HTTPS_PROXY=http://127.0.0.1:7890
# (порт смотрите в настройках «HTTP proxy» / Mixed port.)

# Опционально: модель для scripts/anthropic-smoke.mjs и anthropic-task.mjs
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Локальные проверки (из корня репозитория):
#   yarn anthropic:smoke   — один короткий запрос к API
#   yarn anthropic:task    — разбор docs/ARCHITECTURE.md в стиле чеклиста PR
